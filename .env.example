NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=file:/data/macops.sqlite
SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_MOCK_ENABLED=true
INTEGRATION_MODE=mock

PING_ENTRY_POINT=https://ping.example.org/idp/SSO.saml2
PING_IDP_CERT_PATH=/run/secrets/ping-idp-cert.pem
PING_ALLOWED_GROUPS=Gebruikers Ondersteuning,LiMa
PING_GROUP_ATTRIBUTE=groups

ABM_CLIENT_ID=
ABM_KEY_ID=
ABM_PRIVATE_KEY_PATH=/run/secrets/abm-private-key.pem
ABM_SCOPE=business.api

JAMF_BASE_URL=https://your-server.jamfcloud.com
JAMF_CLIENT_ID=
JAMF_CLIENT_SECRET_PATH=/run/secrets/jamf-client-secret

SERVICENOW_BASE_URL=https://instance.service-now.com
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET_PATH=/run/secrets/servicenow-client-secret
